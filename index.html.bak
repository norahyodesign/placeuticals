<script>
(function () {
  'use strict';

  /* ── Nav: hero 구간에서 투명, 벗어나면 흰 배경 ── */
  var nav = document.getElementById('plt-nav');
  var hero = document.getElementById('hero');

  function updateNav() {
    if (!hero) return;
    var heroBottom = hero.getBoundingClientRect().bottom;
    if (heroBottom > 60) {
      nav.classList.add('on-hero');
    } else {
      nav.classList.remove('on-hero');
    }
  }

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  /* ── Mobile hamburger ── */
  var hamBtn = document.getElementById('nav-ham-btn');
  var drawer = document.getElementById('nav-drawer');

  hamBtn.addEventListener('click', function () {
    var isOpen = drawer.classList.toggle('open');
    hamBtn.setAttribute('aria-label', isOpen ? '메뉴 닫기' : '메뉴 열기');
  });

  drawer.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', function () {
      drawer.classList.remove('open');
      hamBtn.setAttribute('aria-label', '메뉴 열기');
    });
  });

}());
</script>
</body>
</html>
